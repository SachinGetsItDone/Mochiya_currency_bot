# ============================================
# Mochi Bot - Environment Variables Example
# ============================================

# Discord Bot Token (from Discord Developer Portal)
# Required Gateway Intents: Server Members, Message Content, Guild Messages
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN

# Discord Application ID (Client ID)
DISCORD_CLIENT_ID=YOUR_DISCORD_CLIENT_ID

# Command prefix (default: mochi)
COMMAND_PREFIX=mochi

# ============================================
# Supabase Configuration
# ============================================

# Supabase Project URL
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase Service Role Key (NOT the anon key - needs admin privileges for RPC)
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
